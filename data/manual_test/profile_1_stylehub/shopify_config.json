  "updated_by": "MANUAL-TEST",
  "config_version": "2.1",

  "column_mappings": {
    "version": 2,
    "orders": {
      "Name": "Order_Number",
      "Lineitem sku": "SKU",
      "Lineitem quantity": "Quantity",
      "Lineitem name": "Product_Name",
      "Shipping Method": "Shipping_Method",
      "Shipping Country": "Shipping_Country",
      "Tags": "Tags",
      "Notes": "Notes",
      "Total": "Total_Price",
      "Subtotal": "Subtotal",
      "Email": "Email",
      "Financial Status": "Financial_Status"
    },
    "stock": {
      "Артикул": "SKU",
      "Ime": "Product_Name",
      "Наличност": "Stock"
    }
  },

  "courier_mappings": {
    "DHL": {
      "patterns": ["dhl", "dhl express", "dhl standard", "dhl international"]
    },
    "DPD": {
      "patterns": ["dpd", "dpd standard"]
    },
    "Speedy": {
      "patterns": ["speedy"]
    },
    "PostOne": {
      "patterns": ["postone", "post one"]
    }
  },

  "settings": {
    "stock_csv_delimiter": ";",
    "orders_csv_delimiter": ",",
    "low_stock_threshold": 5,
    "repeat_detection_days": 1
  },

  "rules": [
    {
      "name": "Tag DHL orders as EXPRESS-DELIVERY",
      "priority": 1,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Shipping_Method",
          "operator": "contains",
          "value": "DHL"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "EXPRESS-DELIVERY"
        }
      ]
    },
    {
      "name": "Tag Germany orders with internal tag",
      "priority": 2,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Shipping_Country",
          "operator": "equals",
          "value": "Germany"
        }
      ],
      "actions": [
        {
          "type": "ADD_INTERNAL_TAG",
          "value": "DE-ORDER"
        }
      ]
    },
    {
      "name": "Tag high-value orders (Total > 200)",
      "priority": 3,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Total_Price",
          "operator": "is greater than",
          "value": "200"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "HIGH-VALUE"
        }
      ]
    },
    {
      "name": "Tag VIP customer orders",
      "priority": 4,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Tags",
          "operator": "contains",
          "value": "VIP"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "VIP-PRIORITY"
        }
      ]
    },
    {
      "name": "Tag bulk quantity lines (qty > 5)",
      "priority": 5,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Quantity",
          "operator": "is greater than",
          "value": "5"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "BULK-QTY"
        }
      ]
    },
    {
      "name": "Tag multi-item orders with internal tag",
      "priority": 6,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Order_Type",
          "operator": "equals",
          "value": "Multi"
        }
      ],
      "actions": [
        {
          "type": "ADD_INTERNAL_TAG",
          "value": "MULTI-ITEM"
        }
      ]
    }
  ],

  "set_decoders": {
