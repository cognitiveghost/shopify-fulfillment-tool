{
  "client_id": "BEAUTYBOX",
  "client_name": "BeautyBox",
  "created_at": "2026-04-04T10:00:00.000000",
  "last_updated": "2026-04-04T10:00:00.000000",
  "updated_by": "MANUAL-TEST",
  "config_version": "2.1",

  "column_mappings": {
    "version": 2,
    "orders": {
      "Name": "Order_Number",
      "Lineitem sku": "SKU",
      "Lineitem quantity": "Quantity",
      "Lineitem name": "Product_Name",
      "Shipping Method": "Shipping_Method",
      "Shipping Country": "Shipping_Country",
      "Tags": "Tags",
      "Notes": "Notes",
      "Total": "Total_Price",
      "Subtotal": "Subtotal",
      "Email": "Email",
      "Financial Status": "Financial_Status"
    },
    "stock": {
      "Артикул": "SKU",
      "Ime": "Product_Name",
      "Наличност": "Stock",
      "Годност": "Expiry_Date",
      "Партида": "Batch"
    }
  },

  "courier_mappings": {
    "DHL": {
      "patterns": ["dhl", "dhl express", "dhl priority"]
    },
    "Nova Poshta": {
      "patterns": ["nova poshta", "nova post", "np"]
    },
    "Meest": {
      "patterns": ["meest", "meest express"]
    },
    "Justin": {
      "patterns": ["justin"]
    }
  },

  "settings": {
    "stock_csv_delimiter": ";",
    "orders_csv_delimiter": ",",
    "low_stock_threshold": 5,
    "repeat_detection_days": 1
  },

  "rules": [
    {
      "name": "Tag DHL orders as DHL-EXPRESS",
      "priority": 1,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Shipping_Method",
          "operator": "contains",
          "value": "DHL"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "DHL-EXPRESS"
        }
      ]
    },
    {
      "name": "Tag high-value orders (Total > 500) — two actions",
      "priority": 2,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Total_Price",
          "operator": "is greater than",
          "value": "500"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "HIGH-VALUE"
        },
        {
          "type": "ADD_INTERNAL_TAG",
          "value": "vip"
        }
      ]
    },
    {
      "name": "Tag fragile orders (Tags contains FRAGILE)",
      "priority": 3,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Tags",
          "operator": "contains",
          "value": "FRAGILE"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "HANDLE-WITH-CARE"
        }
      ]
    },
    {
      "name": "Tag bulk quantity lines (qty > 20)",
      "priority": 4,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Quantity",
          "operator": "is greater than",
          "value": "20"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "BULK-ORDER"
        }
      ]
    },
    {
      "name": "Tag Ukraine orders with internal tag",
      "priority": 5,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Shipping_Country",
          "operator": "equals",
          "value": "Ukraine"
        }
      ],
      "actions": [
        {
          "type": "ADD_INTERNAL_TAG",
          "value": "UA-LOCAL"
        }
      ]
    },
    {
      "name": "Tag gift set orders (SKU contains GIFT)",
      "priority": 6,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "SKU",
          "operator": "contains",
          "value": "GIFT"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "GIFT-PACKAGING"
        }
      ]
    },
    {
      "name": "Tag urgent orders (Notes contains urgent)",
      "priority": 7,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Notes",
          "operator": "contains",
          "value": "urgent"
        }
      ],
      "actions": [
        {
          "type": "ADD_TAG",
          "value": "URGENT"
        }
      ]
    },
    {
      "name": "Tag multi-item orders with internal tag",
      "priority": 8,
      "enabled": true,
      "match": "ALL",
      "conditions": [
        {
          "field": "Order_Type",
          "operator": "equals",
          "value": "Multi"
        }
      ],
      "actions": [
        {
          "type": "ADD_INTERNAL_TAG",
          "value": "multi-item"
        }
      ]
    }
  ],

  "set_decoders": {
    "BB-STARTER-KIT": [
